{
  "name": "localdb-manager",
  "version": "0.1.0",
  "description": "Your local environment, simplified.",
  "author": "Vitor Vieira",
  "private": true,
  "main": "public/main.js",
  "homepage": "./",
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-scripts": "^5.0.1",
    "wait-on": "^9.0.10",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron:serve": "concurrently -k \"cross-env BROWSER=none npm start\" \"npm run electron:start\"",
    "electron:build": "npm run build && electron-builder -mwl",
    "electron:start": "wait-on tcp:3000 && electron ."
  },
  "build": {
    "extends": null,
    "appId": "com.vitorvieira.localdbmanager",
    "productName": "LocalDB Manager",
    "directories": {
      "buildResources": "public"
    },
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "extraMetadata": {
      "main": "build/main.js"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "public/logo512.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/logo512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/logo512.png"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  }
}